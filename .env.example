# Copy this file to .env and fill values locally.
# Do not commit .env.

# Required to send traces to LangSmith.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=support-engineer-learning-lab
LANGSMITH_ENDPOINT=https://beta.api.smith.langchain.com

# Optional. Only needed for commands run with --real-llm.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
